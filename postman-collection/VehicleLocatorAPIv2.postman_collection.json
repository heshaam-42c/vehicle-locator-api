      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.token != null) {",
              "    pm.collectionVariables.set(\"bearerAuth\", jsonData.token);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {}
          }
